\definecolor{crimson}{RGB}{215, 38, 56}
\definecolor{steelblue}{RGB}{20, 133, 219}
\definecolor{carrot}{RGB}{244, 157, 55}
\definecolor{spec}{RGB}{204,102,0}
\definecolor{dark-green}{RGB}{0,102,0}
\definecolor{newtype}{RGB}{255, 30, 30}

