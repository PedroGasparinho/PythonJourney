\lstdefinelanguage{mypython}
{
mathescape=false,
aboveskip=1pt,
basicstyle=\ttfamily,
keywords={def, class, from, import, lambda, as, assert, break, continue, del, if, else, elif, except, finally, for, global, in, is, 
  not, nonlocal, or, pass, raise, return, try, while, with, yield},
keywords=[2]{str, int, float, complex, list, tuple, range, dict, set, frozenset, bool, bytes, bytearray, memoryview, NoneType},
%keywords=[3]{upper, input, open, write, print}, % python functions
%keywords=[4]{os, sys}, % python classes
%keywords=[5]{fibonacci, __init__, greet, __name__}, % user-defined functions
%keywords=[6]{SampleClass, ValueError}, % user-defined classes
keywordstyle={\color{crimson}},
keywordstyle=[2]{\color{carrot}},
%keywordstyle=[3]{\color{carrot}},
%keywordstyle=[4]{\color{green2}},
%keywordstyle=[5]{\color{carrot}},
%keywordstyle=[6]{\color{green2}},
moredelim=[s][\color{steelblue}]{"}{"},
moredelim=[s][\color{steelblue}]{'}{'},
moredelim=*[s][\color{steelblue}]{f"}{"},
moredelim=[s][\color{steelblue}]{f'}{'},
moredelim=*[s][]{\{}{\}},
commentstyle=\itshape\color{commentgrey},
morecomment=[l]{\#},
columns=[l]fullflexible,
sensitive=true,
escapeinside={*?}{?*},
keepspaces=true,
}

\newcounter{lst}

\lstnewenvironment{pythonlst}[1][none]{
  \lstset{language=mypython,numbers=#1,caption={\vspace*{-2em}},aboveskip=-1em, basicstyle=\ttfamily\footnotesize}
} {\addtocounter{lst}{1}}